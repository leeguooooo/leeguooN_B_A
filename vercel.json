{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/manual-refresh",
      "dest": "/api/manual-refresh.js"
    },
    {
      "src": "/api/cron-refresh",
      "dest": "/api/cron-refresh.js"
    },
    {
      "src": "/api/cache-status",
      "dest": "/api/cache-status.js"
    },
    {
      "src": "/api/updateGames",
      "dest": "/api/updateGames.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/app.js"
    }
  ],
  "crons": [

  ],
  "env": {
    "CRON_SECRET": "8f71d53c-8d5e-4b8a-b6d9-74e9c5a4e8f7",
    "API_KEY": "kuaikuaishiyongshuangjiegunheiheihahei",
    "VERCEL": "1"
  }
}
